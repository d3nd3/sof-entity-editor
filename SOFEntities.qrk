            t_originpoly=!
            angle = "360"
            distance = "90"
            dmg = "2"
            speed = "100"
            wait = "3"
            ;desc = "A door that will rotate. You need to have an origin brush as part of this entity. The center of that brush will be the point around which it is rotated"
          }
          func_door_rotating_smart:b =
          {
            t_originpoly=!
            angle = "360"
            distance = "90"
            dmg = "2"
            speed = "100"
            wait = "3"
            ;desc = "The door will open in the direction opposite that of its activator"
          }
          func_door_secret:b =
          {
            t_triggerpoly=!
            angle = "360"
            dmg = "2"
            wait = "5"
            ;desc = "A secret door. Slide back and then to the side"
          }
        }
        func_fade:e =
        {
          origin = "0 0 0"
          delay = "5"
          ;desc = "Fade the screen to a solid color"
        }
        func_group:b =
        {
          t_triggerpoly=!
          ;desc = "Used to group brushes together just for editor convenience. (And not needed for QuArK;-)"
        }
        func_hide_the_players_gun:e =
