        {
          e_waterglobenpoly=!
          ;desc = "Drip water from a 30 by 30 region -- Resizing the 32 by 32 brush is unnecessary"
        }
        //environ_windgen:e = {origin = "0 0 0";desc = "Not in yet, chump"}
      }
      func.qtxfolder =
