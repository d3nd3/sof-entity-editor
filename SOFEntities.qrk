          origin = "0 0 0"
          ;desc = "Sets the current world ambient sound set to be played"
        }
        func_areaportal:b =
        {
          t_triggerpoly=!
          ;desc = "This is a non-visible object that divides the world into areas that are seperated when this portal is not activated. Usually enclosed in the middle of a door"
        }
        func_breakable_brush:b =
        {
          t_triggerpoly=!
          dmg = "0"
          ;desc = "A breakable brush which has chunk size and type based upon the size and type of the brush"
        }
        func_button:b =
        {
          t_triggerpoly=!
          angle = "360"
          speed = "40"
          wait = "1"
          lip = "4"
          ;desc = "When a button is touched, it moves some distance in the direction of it's angle, triggers all of it's targets, waits some time, then returns to it's original position where it can be triggered again"
        }
        func_camerashake:e =
        {
          origin = "0 0 0"
          count = "30"
          delay = "3"
          health = "300"
          ;desc = "Shakes the camera, centered on where the func is"
        }
        //func_clock:e = {origin = "0 0 0";desc = "Target a target_string with this. The default is to be a time of day clock. TIMER_UP and TIMER_DOWN run for 'count' seconds and the fire 'pathtarget'. If START_OFF, this entity must be used before it starts"}
        func_conveyor:b =
        {
          t_triggerpoly=!
          speed = "100"
          ;desc = "Conveyors are stationary brushes that move what's on them. The brush should be have a surface with at least one current content enabled"
        }
        door.qtxfolder =
        {
          func_door:b =
