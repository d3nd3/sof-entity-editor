QQRKSRC1
{
  // SOF entities file for QuArK
  
  QuArKProtected = "1"
  Description = "SOF Entities (updated)"

  // why does this not work ?
  //  orig_tex:incl= {;incl[] = "[:Games:KingPin:OriginTextureDef]"}
  //  trig_tex:incl= {;incl[] = "[:Games:KingPin:TriggerTextureDef]"}
  orig_tex:incl   = {tex = "armory/origin"}
  trig_tex:incl   = {tex = "armory/trigger"}
  region_tex:incl = {tex = "armory/con2"} // It can be any texture
  
  t_originpoly:incl =
  {
    ORIGIN:p =
    {
      east:f  = {v=' 64   0   0  64 128   0  64   0 128' orig_tex=!}
      west:f  = {v='-64   0   0 -64   0 128 -64 128   0' orig_tex=! m= "1"}
      north:f = {v='  0  64   0   0  64 128 128  64   0' orig_tex=! m= "1"}
      south:f = {v='  0 -64   0 128 -64   0   0 -64 128' orig_tex=!}
      up:f    = {v='  0   0  64 128   0  64   0 128  64' orig_tex=!}
      down:f  = {v='  0   0 -64   0 128 -64 128   0 -64' orig_tex=! m= "1"}
    }
    poly:p =
    {
      east:f  = {v=' 32 -32 -32  32  96 -32  32 -32  96' tex="[auto]"}
      west:f  = {v='-32 -32 -32 -32 -32  96 -32  96 -32' tex="[auto]" m= "1"}
      north:f = {v='-32  32 -32 -32  32  96  96  32 -32' tex="[auto]" m= "1"}
      south:f = {v='-32 -32 -32  96 -32 -32 -32 -32  96' tex="[auto]"}
      up:f    = {v='-32 -32  32  96 -32  32 -32  96  32' tex="[auto]"}
      down:f  = {v='-32 -32 -32 -32  96 -32  96 -32 -32' tex="[auto]" m= "1"}
    }
  }
  t_triggerpoly:incl =
  {
    poly:p =
    {
      east:f  = {v=' 64   0   0  64 128   0  64   0 128' trig_tex=!}
      west:f  = {v='-64   0   0 -64   0 128 -64 128   0' trig_tex=! m= "1"}
      north:f = {v='  0  64   0   0  64 128 128  64   0' trig_tex=! m= "1"}
      south:f = {v='  0 -64   0 128 -64   0   0 -64 128' trig_tex=!}
      up:f    = {v='  0   0  64 128   0  64   0 128  64' trig_tex=!}
      down:f  = {v='  0   0 -64   0 128 -64 128   0 -64' trig_tex=! m= "1"}
    }
  }
  _regionpoly:incl =
  {
    poly:p =
    {
      east:f  = {v=' 64   0   0  64 128   0  64   0 128' region_tex=! }
      west:f  = {v='-64   0   0 -64   0 128 -64 128   0' region_tex=! m= "1"}
      north:f = {v='  0  64   0   0  64 128 128  64   0' region_tex=! m= "1"}
      south:f = {v='  0 -64   0 128 -64   0   0 -64 128' region_tex=! }
      up:f    = {v='  0   0  64 128   0  64   0 128  64' region_tex=! }
      down:f  = {v='  0   0 -64   0 128 -64 128   0 -64' region_tex=! m= "1"}
    }
  }
  e_waterglobenpoly:incl =
  {
    poly:p =
    {
      east:f  = {v=' 32   0  0  32  64  0  32   0 64' tv='0 0 -1280 0 0 -1280' trig_tex=! }
      west:f  = {v='-32   0  0 -32 -64  0 -32   0 64' tv='0 0 -1280 0 0 -1280' trig_tex=! m= "1"}
      north:f = {v='  0  32  0 -64  32  0   0  32 64' tv='0 0 -1280 0 0 -1280' trig_tex=! m= "1"}
      south:f = {v='  0 -32  0  64 -32  0   0 -32 64' tv='0 0 -1280 0 0 -1280' trig_tex=! }
      up:f    = {v='  0   0  4  64   0  4   0  64  4' tv='0 0 -1280 0 0 -1280' trig_tex=! }
      down:f  = {v='  0   0 -4  64   0 -4   0 -64 -4' tv='0 0 -1280 0 0 -1280' trig_tex=! m= "1"}
    }
  }
  Toolbox Folders.qtx =
  {
    ToolBox = "New map items..."
    Root = "SOF Entities.qtxfolder"
    SOF Entities.qtxfolder =
    {
      environment.qtxfolder =
      {
        environ_bloodrain:e =
        {
          origin = "0 0 0"
          ;desc = "Rains from a 30 by 30 region. Put the bloodrain entity at the x-y center of the region you want the blood to rain on. Put it at the height you want the rain to start at"
        }
        environ_chunk_spewer:e =
        {
          origin = "0 0 0"
          ;desc = "Uses an info_notnull as a target, like a func_remote_camera"
        }
        //environ_cloudtrigger:e = {origin = "0 0 0" count = "10" wait = "0.1";desc = ""}
        environ_dustsource:e =
