    func_door_secret:form =
    {
      help =" A secret door. Slide back and then to the side."
      spawnflags: = {Typ = "X1" Txt = "1" Cap = "ALWAYS_SHOOT" Hint = "Door is shootebale even if targeted"}
      spawnflags: = {Typ = "X2" Txt = "2" Cap = "1ST_LEFT"     Hint = "1st move is left of arrow"}
      spawnflags: = {Typ = "X4" Txt = "4" Cap = "1ST_DOWN"     Hint = "1st move is down from arrow"}
      angle:      = {Txt = "&" Hint = "Determines the direction"}
      dmg:        = {Txt = "&" Hint = "Damage to inflic when blocked (default 2)"}
      wait:       = {Txt = "&" Hint = "How long to hold in the open position (default 5, hold = -1)"}
      message:    = {Txt = "&" Hint = "Is printed when the door is touched if it is a trigger door and it hasn't been fired yet"}
      sp_message: = {Txt = "&" Hint = "Is for a string package ID (numerical)"}
      targetname: = {Txt = "&" Hint = "If set, no touch field will be spawned and a remote button or trigger field activates the door"}
    }
    func_fade:form =
    {
      help =""
      bbox ='-8 -8 -8 8 8 8'
      spawnflags: = {Typ = "X1" Txt = "1" Cap = "REVERSE" Hint = "Fades from the color to normal"}
      color:      = {Txt = "&" Hint = "Color to fade to in red green blue format, from 0.0 to 1.0, (with 1.0 being white like 1.0 1.0 1.0)"}
      delay:      = {Txt = "&" Hint = "The length of time it'll take to fully fade (defaults 5) -- NOTE: do NOT set this to zero! If you want instantaneous, use .1"}
    }
    func_group:form =
    {
      help ="Used to group brushes together just for editor convenience. (And not needed for QuArK;-)"
    }
    func_hide_the_players_gun:form =
    {
      help =""
      bbox ='-4 -4 -4 4 4 4'
      wait:  = {Txt = "&" Hint = "If you set wait to -1 then use, count will indicate if we're currently disguised"}
      count: =
      {
        Txt = "&" Typ = "C" Hint = "If you set wait to -1 then use, count will indicate if we're currently disguised"
        Items = "Disguised"$0D"NOT Disguised"
        values = "1"$0D"0"
      }
      health: =
      {
        Txt = "&" Typ = "C" Hint = "1 = if you're disguised, 0 = if you're not"
        Items = "Disguised"$0D"NOT Disguised"
        values = "1"$0D"0"
      }
    }
    func_ignite:form =
    {
      help ="Roast folks"
      bbox ='-8 -8 -8 8 8 8'
      health:     = {Txt = "radius" Hint = "Radius of igniting"}
      targetname: = {Txt = "&"      Hint = "The name to be targgeted from a trigger"}
    }
    func_killbox:form =
    {
      help ="Kills everything inside when fired, irrespective of protection."
      targetname: = {Txt = "&" Hint = "The name to be targgeted from a trigger"}
    }
    func_mission_status:form =
    {
      help ="Near the end of a level, set up 2 trigger_multiples to target this func_mission_status."$0D"One of the triggers should have a targetname of exitwarning_on, the other should be"$0D" called exitwarning_off. place exitwarning_off a short distance from the exit. place"$0D"  exitwarning_on in between exitwarning_off and the exit itself."
      bbox ='-4 -4 -4 4 4 4'
      targetname: = {Txt = "&" Hint = "The name to be targgeted from a trigger"}
      count: =
      {
        Txt = "status" Typ = "C" Hint = "Actual status of the mission. Use to update"
        Items = "Success"$0D"Nothing yet"
        values = "1"$0D"0"
      }
    }
    func_musicControl:form =
    {
      help ="Sets the current state of music."
      bbox ='-8 -8 -8 8 8 8'
      sounds:     = {Txt = "&" Hint = "-2 = turn music off, -1 = let game take over music again, 0-255 = ID number of specific song to be played"}
      targetname: = {Txt = "&" Hint = "The name to be targgeted from a trigger"}
    }
    func_object:form =
    {
      help ="This is solid bmodel that will fall if it's support it removed."
      spawnflags: = {Typ = "X1" Txt = "1" Cap = "TRIGGER_SPAWN" Hint = "Doesn't show up until triggered"}
      spawnflags: = {Typ = "X2" Txt = "2" Cap = "ANIMATED"      Hint = "Have the texture to be animated if it was designed for"}
      spawnflags: = {Typ = "X4" Txt = "4" Cap = "ANIMATED_FAST" Hint = "Have the texture to be animated fast if it was designed for"}
      dmg:        = {Txt = "&" Hint = "Squash thing we fall on top of"}
      targetname: = {Txt = "&" Hint = "The name to be targgeted from a trigger"}
    }
    func_plat:form =
    {
      help ="Plats are always drawn in the extended position, so they will light correctly."$0D"If the plat is the target of another trigger or button, it will start out disabled in the extended position until it is trigger, when it will lower and become a normal plat."
      spawnflags: = {Typ = "X1" Txt = "1" Cap = "PLAT_LOW_TRIGGER" Hint = ""}
      speed:      = {Txt = "&" Hint = "Determines how fast it moves"}
      accel:      = {Txt = "&" Hint = "Rate of acceleration"}
      decel       = {Txt = "&" Hint = "Rate of deceleration"}
      dmg:        = {Txt = "&" Hint = "Damage to inflict when blocked"}
      lip:        = {Txt = "&" Hint = "Pixel lip remaining at end of move (default 8)"}
      height:     = {Txt = "&" Hint = "If this key is set, that will determine the amount the plat moves, instead of being implicitly determoveinfoned by the model's height"}
      targetname: = {Txt = "&" Hint = "The name to be targgeted from a trigger"}
      soundName: =
      {
        Txt = "&" Typ = "C" Hint = "Name of the sound type of the plat"
        Items = "[Plat]Spikey"$0D"[Plat]Barrier"$0D"[Plat]Chain Elevator"$0D"[Door]Normal Wood Single"$0D"[Door]Normal Wood Double"$0D"[Door]Normal Wood Slide 1"$0D"[Door]Normal Swing Metal Light"$0D"[Door]Normal Swing Metal Norm 1"$0D"[Door]Normal Swing Metal Heavy"$0D"[Door]Normal Swing Metal Rusty"$0D"[Door]Normal Elevator"$0D"[Door]Normal Metal Garage"$0D"[Door]Normal Stall Metal"$0D"[Door]HiTech Blast Small"$0D"[Door]HiTech Blast Metal Light 1"$0D"[Door]HiTech Blast Metal Heavy 1"$0D"[Door]HiTech Swing Metal Heavy 1"$0D"[Door]Fridge"$0D"[Door]Pounder"$0D"[Door]Metal Gate"$0D"[Door]Gen Swing 1"$0D"[Door]Special Table"$0D"[Button]Bleep 1"$0D"[Button]Bleep 2"$0D"[Button]Buzz"$0D"[Button]Elevator 1"$0D"[Button]HeliPad"
        Values = "PlatSpikey"$0D"PlatBarrier"$0D"PlatChainElevator"$0D"DoorNormalWoodSingle"$0D"DoorNormalWoodDouble"$0D"DoorNormalWoodSlide1"$0D"DoorNormalSwingMetalLight"$0D"DoorNormalSwingMetalNorm1"$0D"DoorNormalSwingMetalHeavy"$0D"DoorNormalSwingMetalRusty"$0D"DoorNormalElevator"$0D"DoorNormalMetalGarage"$0D"DoorNormalStallMetal"$0D"DoorHiTechBlastSmall"$0D"DoorHiTechBlastMetalLight1"$0D"DoorHiTechBlastMetalHeavy1"$0D"DoorHiTechSwingMetalHeavy1"$0D"DoorFridge"$0D"DoorPounder"$0D"DoorMetalGate"$0D"DoorGenSwing1"$0D"DoorSpecialTable"$0D"ButtonBleep1"$0D"ButtonBleep2"$0D"ButtonBuzz"$0D"ButtonElevator1"$0D"HeliPadButton"
      }
    }
