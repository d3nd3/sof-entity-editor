      help ="Used with target_string (must be on same team)"
      count: = {Txt = "&" Hint = "Is position in the string (starts at 1)"}
    }
    target_crosslevel_target:form =
    {
      help ="Triggered by a trigger_crosslevel elsewhere within a unit. If multiple triggers are checked, all must be true.  Delay, target and"$0D"killtarget also work."
      bbox ='-8 -8 -8 8 8 8'
      spawnflags: = {Typ = "X1" Txt = "1" Cap = "TRIGGER 1" Hint = ""}
      spawnflags: = {Typ = "X1" Txt = "1" Cap = "TRIGGER 2" Hint = ""}
      spawnflags: = {Typ = "X1" Txt = "1" Cap = "TRIGGER 3" Hint = ""}
      spawnflags: = {Typ = "X1" Txt = "1" Cap = "TRIGGER 4" Hint = ""}
      spawnflags: = {Typ = "X1" Txt = "1" Cap = "TRIGGER 5" Hint = ""}
      spawnflags: = {Typ = "X1" Txt = "1" Cap = "TRIGGER 6" Hint = ""}
      spawnflags: = {Typ = "X1" Txt = "1" Cap = "TRIGGER 7" Hint = ""}
      spawnflags: = {Typ = "X1" Txt = "1" Cap = "TRIGGER 8" Hint = ""}
      delay:      = {Txt = "&" Hint = "Delay before using targets if the trigger has been activated (default 1)"}
      target:     = {Txt = "&" Hint = "All entities with a matching targetname will be used"}

    }
    target_crosslevel_trigger:form =
    {
      help ="Once this trigger is touched/used, any trigger_crosslevel_target with the same trigger number is automatically used when a level is started within the same unit.  It is OK to check multiple triggers."
      bbox ='-8 -8 -8 8 8 8'
      spawnflags: = {Typ = "X1" Txt = "1" Cap = "TRIGGER 1" Hint = ""}
      spawnflags: = {Typ = "X1" Txt = "1" Cap = "TRIGGER 2" Hint = ""}
      spawnflags: = {Typ = "X1" Txt = "1" Cap = "TRIGGER 3" Hint = ""}
      spawnflags: = {Typ = "X1" Txt = "1" Cap = "TRIGGER 4" Hint = ""}
      spawnflags: = {Typ = "X1" Txt = "1" Cap = "TRIGGER 5" Hint = ""}
      spawnflags: = {Typ = "X1" Txt = "1" Cap = "TRIGGER 6" Hint = ""}
      spawnflags: = {Typ = "X1" Txt = "1" Cap = "TRIGGER 7" Hint = ""}
      spawnflags: = {Typ = "X1" Txt = "1" Cap = "TRIGGER 8" Hint = ""}
      delay:      = {Txt = "&" Hint = ""}
      message:    = {Txt = "&" Hint = "Text printed"}
      sp_message: = {Txt = "&" Hint = "Is for a string package ID (numerical)"}
      target:     = {Txt = "&" Hint = "All entities with a matching targetname will be used"}
      targetname: = {Txt = "&" Hint = "The name to be targgeted from a trigger"}
    }
    target_earthquake:form =
    {
      help ="When triggered, this initiates a level-wide earthquake."$0D"All players and monsters are affected."
      bbox ='-8 -8 -8 8 8 8'
