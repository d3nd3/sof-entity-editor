    func_trigger_brush:form =
    {
      help ="A brush that can take damage to a point, then call its triggers."
      spawnflags: = {Typ = "X1" Txt = "1" Cap = "NO_DRAW"   Hint = "Make this brush invisible"}
      spawnflags: = {Typ = "X2" Txt = "2" Cap = "START_OFF" Hint = "This entity must be used before it starts"}
      health:     = {Txt = "&" Hint = "Amount of damage it can take before it fires its targets (defaults 100)"}
      target:     = {Txt = "&" Hint = "Name of its targets to fire when this brush is killed"}
      targetname: = {Txt = "&" Hint = "The name to be targgeted from a trigger"}
    }
    func_wall:form =
    {
      help ="This is just a solid wall if not inhibited"
      spawnflags: = {Typ = "X1"  Txt = "1"  Cap = "TRIGGER_SPAWN" Hint = "Walls the wall will initially be present"}
      spawnflags: = {Typ = "X2"  Txt = "2"  Cap = "TOGGLE"        Hint = "Only valid for TRIGGER_SPAWN walls this allows the wall to be turned on and off"}
      spawnflags: = {Typ = "X4"  Txt = "4"  Cap = "START_ON"      Hint = "Only valid for TRIGGER_SPAWN walls the wall will initially be present"}
      spawnflags: = {Typ = "X8"  Txt = "8"  Cap = "ANIMATED"      Hint = "Have the texture to be animated if it was designed for"}
      spawnflags: = {Typ = "X16" Txt = "16" Cap = "ANIMATED_FAST" Hint = "Have the texture to be animated fast if it was designed for"}
      targetname: = {Txt = "&" Hint = "The name to be targgeted from a trigger"}
    }
    func_water:form =
    {
      help ="func_water is a moveable water brush. It must be targeted to operate. Use a non-water texture at your own risk."
      spawnflags: = {Typ = "X1" Txt = "1" Cap = "START_OPEN" Hint = "Causes the water to move to its destination when spawned and operate in reverse"}
      angle:      = {Txt = "&" Hint = "Determines the opening direction (up or down only)"}
      lip:        = {Txt = "&" Hint = "Pixel lip remaining at end of move (default 0)"}
      speed:      = {Txt = "&" Hint = "Movement speed (default 25)"}
      wait:       = {Txt = "&" Hint = "Wait before returning (default -1, TOGGLE = -1)"}
      targetname: = {Txt = "&" Hint = "The name to be targgeted from a trigger"}
      soundName: =
      {
        Txt = "sound" Typ = "C" Hint = "Sound for the WATER"
        Items = "No sound"$0D"Water"$0D"Lava"
        values = "0"$0D"1"$0D"2"
      }
    }
