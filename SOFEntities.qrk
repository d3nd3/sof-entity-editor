  Entity forms.fctx =
  {
    _region:form =
    {
      help ="For FOG Areas"
      fog_chop_size:     = {Txt = "&" Hint = "Size bsp should break up (default 128)"}
      fog_color:         = {Txt = "&" Hint = "Vector RGB (0 to 255 for each color value )"}
      fog_density:       = {Txt = "&" Hint = "(0.0 to 1.0)"}
      fog_density_range: = {Txt = "&" Hint = "The range for the density of the fog (-1.0 to 1.0)"}
      fog_distance_cull: = {Txt = "&" Hint = "Distance for culling fog areas"}
      fog_end:           = {Txt = "&" Hint = "fog_start to infinity (recommended 400.0)"}
      fog_height:        = {Txt = "&" Hint = "fog_start to infinity"}
      fog_start:         = {Txt = "&" Hint = "Start distance radius. -- 0.0 to infinity (recommended 4.0)"}
      fog_time:          = {Txt = "&" Hint = "Speed of the fog's movements"}
      fog_flags: =
      {
        Txt = "&" Typ = "C" Hint = ""
        Items = "Pulsate"$0D"Height"$0D"Map"$0D"Anti"
        values = "1"$0D"2"$0D"4"$0D"8"
      }
      fog_mode: =
      {
        Txt = "&" Typ = "C" Hint = ""
        Items = "Normal"$0D"Additive"
        values = "0"$0D"1"
      }
    }
    dm_KOTH_targetzone:form =
    {
      spawnflags: = {Typ = "X1" Txt = "1" Cap = "START_OFF" Hint = "Will turn on if triggered"}
    }
    path_corner:form =
    {
      help =""
      bbox ='-8 -8 -8 8 8 8'
      spawnflags:  = {Typ = "X1" Txt = "1" Cap = "TELEPORT"     Hint = ""}
      spawnflags:  = {Typ = "X2" Txt = "2" Cap = "WAITONECYCLE" Hint = "Ignores wait time, goes through waitactions once"}
      spawnflags:  = {Typ = "X4" Txt = "4" Cap = "FACEPLAYER"   Hint = "Will face the player forever, once it reaches this point"}
      waitaction1: = {Txt = "&" Hint = "Animations to play while waiting"}
      waitaction2: = {Txt = "&" Hint = "Animations to play while waiting"}
      waitaction3: = {Txt = "&" Hint = "Animations to play while waiting"}
      waitaction4: = {Txt = "&" Hint = "Animations to play while waiting"}
      waitaction5: = {Txt = "&" Hint = "Animations to play while waiting"}
      waitaction6: = {Txt = "&" Hint = "Animations to play while waiting"}
      wait:        = {Txt = "&" Hint = "Time to wait (-1 for forever)"}
      moveAction:  = {Txt = "&" Hint = "Animation to play while moving to the next path_corner"}
      pathtarget:  = {Txt = "&" Hint = "Gets used when an entity that has this path_corner targeted touches it"}
      target:      = {Txt = "&" Hint = "Next path_corner"}
      targetname:  = {Txt = "&" Hint = "The name to be targgeted from a trigger"}
    }
    point_combat:form =
    {
      help ="Makes this the target of a monster and it will head here"$0D"when first activated before going after the activator. "$0D"If HOLD is selected, it will stay here."
      bbox ='-8 -8 -8 8 8 8'
      spawnflags:  = {Typ = "X1" Txt = "1" Cap = "HOLD"         Hint = ""}
      spawnflags:  = {Typ = "X2" Txt = "2" Cap = "WAITONECYCLE" Hint = "Ignores wait time, goes through waitactions once"}
      spawnflags:  = {Typ = "X4" Txt = "4" Cap = "FACEPLAYER"   Hint = "Will face the player forever, once it reaches this point"}
      waitaction1: = {Txt = "&" Hint = "Animations to play while waiting"}
      waitaction2: = {Txt = "&" Hint = "Animations to play while waiting"}
      waitaction3: = {Txt = "&" Hint = "Animations to play while waiting"}
      waitaction4: = {Txt = "&" Hint = "Animations to play while waiting"}
      waitaction5: = {Txt = "&" Hint = "Animations to play while waiting"}
      waitaction6: = {Txt = "&" Hint = "Animations to play while waiting"}
      wmoveAction: = {Txt = "&" Hint = "Animation to play while moving to the next point_combat"}
      pathtarget:  = {Txt = "&" Hint = "Gets used when an entity that has this point_combat targeted touches it"}
      target:      = {Txt = "&" Hint = "Next point_combat"}
      targetname:  = {Txt = "&" Hint = "The name to be targgeted from a trigger"}
    }
    script_runner:form =
    {
      help ="Set Script to the name of the script to run when triggered use parm1 through parm16 to send parameters to the script"
      bbox ='-8 -8 -8 8 8 8'
      spawnflags: = {Typ = "X1" Txt = "1" Cap = "WILL_KILL_USER" Hint = "If used from a monster's killtarget, the monster won't kill itself and must be killed from the script"}
      script:     = {Txt = "&" Hint = "Name of script"}
      parm1:      = {Txt = "&" Hint = "Parameter 1 of script"}
      parm2:      = {Txt = "&" Hint = "Parameter 2 of script"}
      parm3:      = {Txt = "&" Hint = "Parameter 3 of script"}
      parm4:      = {Txt = "&" Hint = "Parameter 4 of script"}
      parm5:      = {Txt = "&" Hint = "Parameter 5 of script"}
      parm6:      = {Txt = "&" Hint = "Parameter 6 of script"}
      parm7:      = {Txt = "&" Hint = "Parameter 7 of script"}
      parm8:      = {Txt = "&" Hint = "Parameter 8 of script"}
      parm9:      = {Txt = "&" Hint = "Parameter 9 of script"}
      parm10:     = {Txt = "&" Hint = "Parameter 10 of script"}
      parm11:     = {Txt = "&" Hint = "Parameter 11 of script"}
      parm12:     = {Txt = "&" Hint = "Parameter 12 of script"}
      parm13:     = {Txt = "&" Hint = "Parameter 13 of script"}
      parm14:     = {Txt = "&" Hint = "Parameter 14 of script"}
      parm15:     = {Txt = "&" Hint = "Parameter 15 of script"}
      parm16:     = {Txt = "&" Hint = "Parameter 16 of script"}
      targetname: = {Txt = "&" Hint = "The name to be targgeted from a trigger"}
    }
    spawner:form =
    {
      help =""
      bbox ='-16 -16 -32 16 16 32'
      spawnflags: = {Typ = "X1" Txt = "1" Cap = "START_OFF" Hint = "Doesn't appear until used"}
      spawnflags: = {Typ = "X2" Txt = "2" Cap = "SINGLE_TYPE" Hint = ""}
      spawn1:     = {Txt = "&" Hint = "Name of the ent to spawn from the ent list"}
      spawn2:     = {Txt = "&" Hint = "Name of the ent to spawn from the ent list"}
      spawn3:     = {Txt = "&" Hint = "Name of the ent to spawn from the ent list"}
      count:      = {Txt = "&" Hint = "Number of ents to be spawned at a single time (default 1)"}
      delay:      = {Txt = "&" Hint = "Frequency to spawn an ent in normal circumstances (default 30)"}
      health:     = {Txt = "&" Hint = "Number of items to spawn before removing - -1 is unlimited (default -1)"}
      lip:        = {Txt = "&" Hint = "Minimum radius to spawn guys in when you're not facing the spawner (default 450)"}
      mass:       = {Txt = "&" Hint = "Maximum number of ents owned by this trigger that can be in the world at once (default 1) ... -1 is unlimited"}
      wait:       = {Txt = "&" Hint = "Frequency to spawn an ent in triggered/active circumstances (default 10)"}
      targetname: = {Txt = "&" Hint = "The name to be targgeted from a trigger"}
      soundName: =
      {
        Txt = "&" Typ = "C" Hint = "Door sound to be played when spawner is activated"
        Items = "[Door]Normal Wood Single"$0D"[Door]Normal Wood Double"$0D"[Door]Normal Wood Slide 1"$0D"[Door]Normal Swing Metal Light"$0D"[Door]Normal Swing Metal Norm 1"$0D"[Door]Normal Swing Metal Heavy"$0D"[Door]Normal Swing Metal Rusty"$0D"[Door]Normal Elevator"$0D"[Door]Normal Metal Garage"$0D"[Door]Normal Stall Metal"$0D"[Door]HiTech Blast Small"$0D"[Door]HiTech Blast Metal Light 1"$0D"[Door]HiTech Blast Metal Heavy 1"$0D"[Door]HiTech Swing Metal Heavy 1"$0D"[Door]Fridge"$0D"[Door]Pounder"$0D"[Door]Metal Gate"$0D"[Door]Gen Swing 1"$0D"[Door]Special Table"$0D"[Button]Bleep 1"$0D"[Button]Bleep 2"$0D"[Button]Buzz"$0D"[Button]Elevator 1"$0D"[Button]HeliPad"$0D"[Plat]Spikey"$0D"[Plat]Barrier"$0D"[Plat]Chain Elevator"
        Values = "DoorNormalWoodSingle"$0D"DoorNormalWoodDouble"$0D"DoorNormalWoodSlide1"$0D"DoorNormalSwingMetalLight"$0D"DoorNormalSwingMetalNorm1"$0D"DoorNormalSwingMetalHeavy"$0D"DoorNormalSwingMetalRusty"$0D"DoorNormalElevator"$0D"DoorNormalMetalGarage"$0D"DoorNormalStallMetal"$0D"DoorHiTechBlastSmall"$0D"DoorHiTechBlastMetalLight1"$0D"DoorHiTechBlastMetalHeavy1"$0D"DoorHiTechSwingMetalHeavy1"$0D"DoorFridge"$0D"DoorPounder"$0D"DoorMetalGate"$0D"DoorGenSwing1"$0D"DoorSpecialTable"$0D"ButtonBleep1"$0D"ButtonBleep2"$0D"ButtonBuzz"$0D"ButtonElevator1"$0D"HeliPadButton"$0D"PlatSpikey"$0D"PlatBarrier"$0D"PlatChainElevator"
      }
    }
    spawner_monster:form =
    {
      help =""
      bbox ='-16 -16 -32 16 16 32'
      spawnflags: = {Typ = "X1"  Txt = "1"  Cap = "START_OFF"        Hint = "Doesn't appear until used"}
      spawnflags: = {Typ = "X2"  Txt = "2"  Cap = "SINGLE_TYPE"      Hint = ""}
      spawnflags: = {Typ = "X4"  Txt = "4"  Cap = "TARGET_PLAYER"    Hint = "Makes spawned guys default to attacking the player immediately"}
      spawnflags: = {Typ = "X8"  Txt = "8"  Cap = "IGNORE_VISIBLITY" Hint = "Spawn a guy even with the spawner being visible to player"}
      spawnflags: = {Typ = "X16" Txt = "16" Cap = "IGNORE_LIMITS"    Hint = ""}
