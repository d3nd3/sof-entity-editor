      targetname: = {Txt = "&" Hint = "The name to be targgeted from a trigger"}
    }
    target_goal:form =
    {
      help ="Counts a goal completed."$0D"These are single use targets."
      bbox ='-8 -8 -8 8 8 8'
      message:    = {Txt = "&" Hint = "Text printed"}
      sp_message: = {Txt = "&" Hint = "Is for a string package ID (numerical)"}
      target:     = {Txt = "&" Hint = "All entities with a matching targetname will be used"}
      targetname: = {Txt = "&" Hint = "The name to be targgeted from a trigger"}
    }
    target_help:form =
    {
      help ="When fired, the message key becomes the current personal computer string, and the message light will be set on all clients status bars."
      bbox ='-16 -16 -24 16 16 24'
      spawnflags: = {Typ = "X1" Txt = "1" Cap = "HELP 1" Hint = ""}
      message:    = {Txt = "&" Hint = "Text printed"}
      targetname: = {Txt = "&" Hint = "The name to be targgeted from a trigger"}
    }
    target_laser:form =
    {
      help ="When triggered, fires a laser. You can either set a target"$0D"or a direction."
      bbox ='-8 -8 -8 8 8 8'
      spawnflags: = {Typ = "X1"  Txt = "1"  Cap = "START_ON" Hint = "Make this entity to begin activated"}
      spawnflags: = {Typ = "X2"  Txt = "2"  Cap = "RED"      Hint = "It'll be red"}
      spawnflags: = {Typ = "X4"  Txt = "4"  Cap = "GREEN"    Hint = "It'll be green"}
      spawnflags: = {Typ = "X8"  Txt = "8"  Cap = "BLUE"     Hint = "It'll be blue. Defaults to red if this flag not set"}
      spawnflags: = {Typ = "X16" Txt = "16" Cap = "YELLOW"   Hint = "It'll be yellow"}
      spawnflags: = {Typ = "X32" Txt = "32" Cap = "ORANGE"   Hint = "It'll be orange"}
      spawnflags: = {Typ = "X64" Txt = "64" Cap = "FAT"      Hint = "Set the beam diameter"}
      dmg:        = {Txt = "&" Hint = "Damage to inflict when touched"}
      target:     = {Txt = "&" Hint = "All entities with a matching targetname will be used"}
      targetname: = {Txt = "&" Hint = "The name to be targgeted from a trigger"}
    }
    target_lightramp:form =
    {
      help =""
      bbox ='-8 -8 -8 8 8 8'
      spawnflags: = {Typ  = "X1" Txt = "1" Cap = "TOGGLE" Hint = "Using through trigger will activate/deactivate"}
      message:    = {Txt = "&" Hint = "Two letters; starting lightlevel and ending lightlevel"}
      speed:      = {Txt = "&" Hint = "How many seconds the ramping will take"}
      target:     = {Txt = "&" Hint = "All 'light' entities with a matching targetname will be used"}
      targetname: = {Txt = "&" Hint = "The name to be targgeted from a trigger"}
    }
    target_secret:form =
    {
      help ="Counts a secret found."$0D"These are single use targets."
      bbox ='-8 -8 -8 8 8 8'
      noise:      = {Txt = "&" Hint = "WAV file to play"}
      target:     = {Txt = "&" Hint = "All entities with a matching targetname will be used"}
      targetname: = {Txt = "&" Hint = "The name to be targgeted from a trigger"}
    }
    target_spawner:form =
    {
      help ="Set target to the type of entity you want spawned."$0D"Useful for spawning monsters and gibs in the factory levels."$0D"For monsters Set direction to the facing you want it to have."$0D"For gibs Set direction if you want it moving and speed how fast it should be moving otherwise it will just be dropped"
      bbox ='-8 -8 -8 8 8 8'
      target:     = {Txt = "entity" Hint = "The entity classname to spawn"}
      angle:      = {Txt = "&"      Hint = "Set direction if you want it moving"}
      speed:      = {Txt = "&"      Hint = "How fast it should be moving otherwise it will just be dropped"}
      targetname: = {Txt = "&"      Hint = "The name to be targgeted from a trigger"}
    }
    target_speaker:form =
    {
      help ="Normal sounds play each time the target is used. The reliable flag can be set for crucial voiceovers."$0D"Looped sounds are always atten 3 / vol 1, and the use function toggles it on/off."$0D"Multiple identical looping sounds will just increase volume without any speed cost."
      bbox ='-8 -8 -8 8 8 8'
      spawnflags:  = {Typ = "X1" Txt = "1" Cap  = "LOOPED-ON"  Hint = "Check for prestarted looping sound"}
      spawnflags:  = {Typ = "X2" Txt = "2" Cap  = "LOOPED-OFF" Hint = "Won't loop until triggered"}
      spawnflags:  = {Typ = "X4" Txt = "4" Cap  = "RELIABLE"   Hint = "Glag can be set for crucial voiceovers"}
      noise:       = {Txt = "&" Hint = "WAV file to play (Do not add the '.wav' extension"}
      volume:      = {Txt = "&" Hint = "0.0 to 1.0"}
      targetname:  = {Txt = "&" Hint = "The name to be targgeted from a trigger"}
      attenuation: =
      {
        Txt = "&" Typ = "C" Hint = "-1 = none, send to whole level, 1 = normal fighting sounds, 2 = idle sound level, 3 = ambient sound level"
        Items = "None"$0D"Normal fighting sounds"$0D"Idle sound level"$0D"Ambient sound level"
        values = "-1"$0D"1"$0D"2"$0D"3"
      }
    }
    target_splash:form =
    {
      help = "Creates a particle splash effect when used."
      bbox ='-8 -8 -8 8 8 8'
      count:      = {Txt = "&" Hint = "How many pixels in the splash"}
      dmg:        = {Txt = "&" Hint = "If set, does a radius damage at this location when it splashes useful for lava/sparks"}
      targetname: = {Txt = "&" Hint = "The name to be targgeted from a trigger"}
    }
    target_string:form =
    {
      help =""
      bbox ='-8 -8 -8 8 8 8'
      team:       = {Txt = "&" Hint = ""}
      message:    = {Txt = "&" Hint = "Text printed"}
      targetname: = {Txt = "&" Hint = "The name to be targgeted from a trigger"}
    }
    target_temp_entity:form =
    {
      help ="Fire an origin based temp entity event to the clients."
      bbox ='-8 -8 -8 8 8 8'
      style:      = {Txt = "&" Hint = "Type byte"}
      targetname: = {Txt = "&" Hint = "The name to be targgeted from a trigger"}
    }
    trigger_activate:form =
    {
      help ="Will make a trigger active if it is inactive, or inactive if it's active"
      target:     = {Txt = "&" Hint = "All entities with a matching targetname will be used"}
      targetname: = {Txt = "&" Hint = "The name to be targgeted from a trigger"}
    }
    trigger_always:form =
    {
      help ="This trigger will always fire. It is activated by the world."
      bbox ='-8 -8 -8 8 8 8'
      delay:      = {Txt = "&" Hint = "Delay between firing"}
      target:     = {Txt = "&" Hint = "All entities with a matching targetname will be used"}
      targetname: = {Txt = "&" Hint = "The name to be targgeted from a trigger"}
    }
    trigger_countdown:form =
    {
      help ="Produces a timer on screen that counts backwards.  When done it fires all of its targets and removes itself. Is activated by touch or use."
      spawnflags: = {Typ = "X1" Txt = "1" Cap = "START_OFF" Hint = "Trigger is turned off so it can't be touched (use trigger_activate to make 'touchable')"}
      spawnflags: = {Typ = "X2" Txt = "2" Cap = "ANY_USE"   Hint = "It can be activated by a trigger, not just by touching it"}
      spawnflags: = {Typ = "X4" Txt = "4" Cap = "REUSEABLE" Hint = "It can used again after the coundown is finished"}
      count:      = {Txt = "&" Hint = "# to start counting backwards from (default 10, can be MUCH bigger than 255)"}
      target:     = {Txt = "&" Hint = "All entities with a matching targetname will be used"}
      targetname: = {Txt = "&" Hint = "The name to be targgeted from a trigger"}
    }
    trigger_counter:form =
    {
      help ="Acts as an intermediary for an action that takes multiple inputs."$0D"If nomessage is not set, t will print 1 more..  etc when triggered and sequence complete when finished."$0D"After the counter has been triggered count times (default 2), it will fire all of it's targets and remove itself."
      spawnflags: = {Typ  = "X1" Txt = "1" Cap = "NOMESSAGE" Hint = "If nomessage is not set, it will print 1 more.. etc when triggered and sequence complete when finished"$0D"After the counter has been triggered 'count' times (default 2), it will fire all of it's targets and remove itself"}
      count:      = {Txt = "&" Hint = "# to start counting backwards from (default 10, can be MUCH bigger than 255)"}
      target:     = {Txt = "&" Hint = "All entities with a matching targetname will be used"}
      targetname: = {Txt = "&" Hint = "The name to be targgeted from a trigger"}
    }
    trigger_elevator:form =
    {
      help =""
      bbox ='-8 -8 -8 8 8 8'
      target:     = {Txt = "&" Hint = "All entities with a matching targetname will be used"}
      pathtarget: = {Txt = "&" Hint = "Gets used when an entity that has this path_corner targeted touches it"}
      targetname: = {Txt = "&" Hint = "The name to be targgeted from a trigger"}
    }
    trigger_gravity:form =
    {
      help ="Changes the touching entites gravity to"$0D"the value of gravity.  1.0 is standard"$0D"gravity for the level."
      gravity: = {Txt = "&" Hint = ""}
    }
    trigger_heal:form =
    {
      help ="A trigger that heals the user only when the player hits the use key."
      health: = {Txt = "&" Hint = "The number of points to be healed (defaults 15)"}
    }
    trigger_hurt:form =
    {
      help ="Any entity that touches this will be hurt"
      spawnflags: = {Typ = "X1"  Txt = "1"  Cap = "START_OFF"     Hint = "Won't fire until trigger_activate is used"}
      spawnflags: = {Typ = "X4"  Txt = "4"  Cap = "SILENT"        Hint = "Does nothing yet"}
      spawnflags: = {Typ = "X8"  Txt = "8"  Cap = "NO_PROTECTION" Hint = "*Nothing* stops the damage"}
      spawnflags: = {Typ = "X16" Txt = "16" Cap = "SLOW"          Hint = "Changes the damage rate to once per second"}
      spawnflags: = {Typ = "X32" Txt = "32" Cap = "PLAYER_ONLY"   Hint = "Trigger will only affect player"}
      spawnflags: = {Typ = "X64" Txt = "64" Cap = "IGNORE_ARMOR"  Hint = "This damage ignores armor"}
      dmg:        = {Txt = "&" Hint = "Points of damage per server frame (default 5) whole numbers only"}
      targetname: = {Txt = "&" Hint = "The name to be targgeted from a trigger"}
    }
    trigger_keep_using:form =
    {
      help ="A trigger that keeps firing as long as the player hits the use key and keeps touching it."
      target:     = {Txt = "&" Hint = "All entities with a matching targetname will be used"}
      targetname: = {Txt = "&" Hint = "The name to be targgeted from a trigger"}
    }
    trigger_key:form =
    {
      help ="A relay trigger that only fires it's targets if player has the proper key."
      bbox ='-8 -8 -8 8 8 8'
      item:       = {Txt = "&" Hint = "To specify the required key, for example key_data_cd"}
      target:     = {Txt = "&" Hint = "All entities with a matching targetname will be used"}
      targetname: = {Txt = "&" Hint = "The name to be targgeted from a trigger"}
    }
    trigger_monsterjump:form =
    {
      help ="Walking monsters that touch this will jump in the direction of the trigger's angle"
      speed:  = {Txt = "&" Hint = "The speed thrown forward (default 200)"}
      height: = {Txt = "&" Hint = "The speed thrown upwards (default 200)"}
      angle:  = {Txt = "&" Hint = "To which angle monsters will jump"}
    }
    trigger_movedown:form =
    {
      help ="A trigger that forces thing downward. Meant to be used in conjunction with pushkill brush."
    }
    trigger_multiple:form =
    {
      help ="Variable sized repeatable trigger. Must be targeted at one or more entities."$0D"If they are NOT targeted, then there are three flags you need to be aware of MONSTER, NO_PLAYER, TRIGGERED"$0D"After this activation, the trigger will be activated when something (depending on how"$0D"the first two flags are set) steps into it.  Since this flag requires the trigger to "$0D"have a targetname, this flag will obviously override the I can't be activated by anything"$0D"but my targeter condition once it has been triggered."
      spawnflags: = {Typ = "X1" Txt = "1" Cap = "MONSTER"    Hint = "Flag must be set if you want a monster to be able to activate the trigger by walking into it"}
      spawnflags: = {Typ = "X2" Txt = "2" Cap = "NOT_PLAYER" Hint = "Flag must be set if you do NOT want the player to be able to activate the trigger by walking into it"}
      spawnflags: = {Typ = "X4" Txt = "4" Cap = "TRIGGERED"  Hint = "This trigger must be triggered before it is live"}
      spawnflags: = {Typ = "X8" Txt = "8" Cap = "USEKEY"     Hint = "This trigger can be activated with the 'use' key"}
      wait:       = {Txt = "&" Hint = "Seconds between triggerings (default 0.2)"}
      delay:      = {Txt = "&" Hint = "The trigger waits some time after activating before firing"}
      message:    = {Txt = "&" Hint = "Text string"}
      sp_message: = {Txt = "&" Hint = "Is for a string package ID (numerical)"}
      target:     = {Txt = "&" Hint = "All entities with a matching targetname will be used"}
      targetname: = {Txt = "&" Hint = "The name to be targgeted from a trigger"}
    }
    trigger_objectives:form =
    {
      help ="Using this entity will toggle the trigger enabled/disabled. When enabled, the trigger will"$0D"display a check your objectives screen message."
      spawnflags: = {Typ = "X1" Txt  = "1" Cap = "START_OFF" Hint = "Won't display anything until used"}
      targetname: = {Txt = "&" Hint = "The name to be targgeted from a trigger"}
    }
    trigger_once:form =
    {
      help ="Triggers once, then removes itself."$0D"You must set the key target to the name of another object in the level that has a matching targetname."
      spawnflags: = {Typ = "X1" Txt = "1" Cap = "MONSTER"    Hint = "Flag must be set if you want a monster to be able to activate the trigger by walking into it"}
      spawnflags: = {Typ = "X2" Txt = "2" Cap = "NOT_PLAYER" Hint = "Flag must be set if you do NOT want the player to be able to activate the trigger by walking into it"}
      spawnflags: = {Typ = "X4" Txt = "4" Cap = "TRIGGERED"  Hint = "This trigger must be triggered before it is live"}
      spawnflags: = {Typ = "X8" Txt = "8" Cap = "USEKEY"     Hint = "This trigger can be activated with the 'use' key"}
      message:    = {Txt = "&" Hint = "Text string"}
      sp_message: = {Txt = "&" Hint = "Is for a string package ID (numerical)"}
      target:     = {Txt = "&" Hint = "All entities with a matching targetname will be used"}
      targetname: = {Txt = "&" Hint = "The name to be targgeted from a trigger"}
    }
    trigger_push:form =
    {
      help ="Pushes the player"
      spawnflags: = {Typ = "X1" Txt = "1" Cap  = "PUSH_ONCE" Hint = "Only works once"}
      spawnflags: = {Typ = "X2" Txt = "2" Cap  = "START_OFF" Hint = "'use' this trigger to turn on the pushing. 'use' it again to turn it off. rinse. Repeat"}
      speed:      = {Txt = "&"  Hint = "Determines how fast the player is pushed (default 1000)"}
      targetname: = {Txt = "&"  Hint = "The name to be targgeted from a trigger"}
    }
    trigger_conquer:form =
    {
      help = "Used to define the conquer area. No special keys are needed. The default conquer texture is iraq/king_hill"
    }
    trigger_relay:form =
    {
      help ="This fixed size trigger cannot be touched, it can only be fired by other events."
      bbox ='-8 -8 -8 8 8 8'
      target:     = {Txt = "&"  Hint = "All entities with a matching targetname will be used"}
      targetname: = {Txt = "&"  Hint = "The name to be targgeted from a trigger"}
    }
    trigger_safezone:form =
    {
      help ="Using this entity will toggle whether it hides players or not."
      spawnflags: = {Typ = "X1" Txt = "1" Cap = "START_OFF" Hint = "Won't hide anybody until trigger is used"}
      targetname: = {Txt = "&"  Hint = "The name to be targgeted from a trigger"}
    }
    trigger_sound:form =
    {
      help ="Will trigger target when noisy things occur nearby (radius for activation is set by health (defaults to 128))"$0D"target will set what it should trigger, of course"
      bbox ='-4 -4 -4 4 4 4'
      health:     = {Txt = "radius" Hint = "Radius for activation (default 128)"}
      target:     = {Txt = "&"      Hint = "All entities with a matching targetname will be used"}
      targetname: = {Txt = "&"      Hint = "The name to be targgeted from a trigger"}
    }
    trigger_useable:form =
    {
      help ="A trigger that fires its targets only when the player hits the use key."
      target:     = {Txt = "&"     Hint = "All entities with a matching targetname will be used"}
      targetname: = {Txt = "sound" Hint = "Name of a sound to be played when the trigger is used. Make sure you put the .wav at the end"}
    }
    worldspawn:form =
    {
      help ="Only used for the world."
      ainame: =
      {
        Txt = "&" Typ = "C" Hint = "Specify monster ai name"
        Items = "tsr1"$0D"tsr2"$0D"trn1"$0D"arm1"$0D"kos1"$0D"kos2"$0D"kos3"$0D"sib1"$0D"sib2"$0D"sib3"$0D"irq1a"$0D"irq2a"$0D"irq3a"$0D"arm2"$0D"nyc1"$0D"nyc2"$0D"nyc3"$0D"sud1"$0D"sud2"$0D"sud3"$0D"arm3"$0D"jpn1"$0D"jpn2"$0D"jpn3"$0D"irq1b"$0D"irq2b"$0D"irq3b"$0D"ger1"$0D"ger2"$0D"ger3"$0D"ger4"$0D"tut1"
        values = "tsr1"$0D"tsr2"$0D"trn1"$0D"arm1"$0D"kos1"$0D"kos2"$0D"kos3"$0D"sib1"$0D"sib2"$0D"sib3"$0D"irq1a"$0D"irq2a"$0D"irq3a"$0D"arm2"$0D"nyc1"$0D"nyc2"$0D"nyc3"$0D"sud1"$0D"sud2"$0D"sud3"$0D"arm3"$0D"jpn1"$0D"jpn2"$0D"jpn3"$0D"irq1b"$0D"irq2b"$0D"irq3b"$0D"ger1"$0D"ger2"$0D"ger3"$0D"ger4"$0D"tut1"
      }
      forceHUD: =
      {
        Txt = "&" Typ = "C" Hint = "Draws HUD even with no weapon"
        Items = "false"$0D"true"
        values = "0"$0D"1"
      }
      noweapons: =
      {
        Txt = "&" Typ = "C" Hint = "For levels like the armory where the player gets no weapons. set to 1 for no weapons"
        Items = "false"$0D"true"
        values = "0"$0D"1"
      }
      setweapons: =
      {
        Txt = "&" Typ = "C" Hint = "Set the player's inventory. For TRN1 and TSR1 use 1. Overridden by noweapons"
        Items = "false"$0D"true"
        values = "0"$0D"1"
      }
      sky: =
      {
        Txt = "&" Typ = "C" Hint = "Environment sky name (type directly to this box for custom sky name)"
        Items = "bos2"$0D"irq"$0D"irq1"$0D"irq2"$0D"ny"$0D"sib"$0D"tok1"$0D"tok2"$0D"train"$0D"tut"$0D"ugan"
        values = "bos2"$0D"irq"$0D"irq1"$0D"irq2"$0D"ny"$0D"sib"$0D"tok1"$0D"tok2"$0D"train"$0D"tut"$0D"ugan"
      }
      terrainset: =
      {
        Txt = "&" Typ = "C" Hint = "Filename of the terrainset for this level" 
        Items = "train"
        values = "train"
      }
      ambientset:       = {Txt = "&" Hint = "Filename of the ambient set for this level. If its blank, then force it to 'sounds/sound.amb'"}
      chop:             = {Txt = "&" Hint = "Sets the surface patch size for lighting"}
      chopsky:          = {Txt = "&" Hint = "Sets the surface patch size for sky"}
      chopwarp:         = {Txt = "&" Hint = "Sets the surface patch size for warp surfaces"}
      distcull:         = {Txt = "&" Hint = "Sets the maximum distance for VIS (100 is good)"}
      gravity:          = {Txt = "&" Hint = "Set the gravity (default 800)"}
      maxDeadHostages:  = {Txt = "&" Hint = "Number of dead hostages allowed before you fail this mission"}
      message:          = {Txt = "&" Hint = "Text to print at user logon"}
      musicset:         = {Txt = "&" Hint = "Filename of the musicset for this level"}
      screeneffect:     = {Txt = "&" Hint = "Sets the style of general screen effect"}
      script:           = {Txt = "&" Hint = "Filename of a script to run at map loadtime"}
      skyaxis:          = {Txt = "&" Hint = "Vector axis for rotating sky"}
      skyrotate:        = {Txt = "&" Hint = "Speed of rotation in degrees/second"}
      spawn1:           = {Txt = "&" Hint = "Types of guys that will be spawned into the world from combat"}
      spawn2:           = {Txt = "&" Hint = "Types of guys that will be spawned into the world from combat"}
      spawn3:           = {Txt = "&" Hint = "Types of guys that will be spawned into the world from combat"}
      spawnfrequency:   = {Txt = "&" Hint = "0..1 from no guys to very likely (default 0)"}
      startmusic:       = {Txt = "&" Hint = "Set if you want to force a specific song at startup"}
      weaponsAvailable: = {Txt = "&" Hint = "Magic number for precaching weapons. Ask a programmer (68 for tutorial level)"$0D0D"Add the sum for each weapons you want to precache"$0D"1         EMPTYSLOT"$0D"2         KNIFE"$0D"4         PISTOL2"$0D"8         PISTOL1"$0D"16       MACHINEPISTOL"$0D"32       ASSAULTRIFLE"$0D"64       SNIPER"$0D"128     AUTOSHOTGUN"$0D"256     SHOTGUN"$0D"512     MACHINEGUN"$0D"1024   ROCKET"$0D"2048   MICROWAVEPULSE"$0D"4086   FLAMEGUN"$0D"8172   HURTHAND"$0D"16344 THROWHAND"}
      _sun_ambient:     = {Txt = "&" Hint = "Is the amount of light received by the shadows that have been cast from the sun. It is like the lighting that is reflected into the areas that do not receive direct sun light. Its value is anywhere from 0 to the _sun_light value"}
      _sun_angle:       = {Txt = "&" Hint = "Sets the angle from which the sun is shining down. It has two numbers that reflect the YAW and PITCH respectively"}
      _sun_color:       = {Txt = "&" Hint = "The color of the light. Is is represented as the vector RGB color (1 0 0 = red)"}
      _sun_diffuse:     = {Txt = "&" Hint = "Is the strength of the shadow lines. The higher the diffuse, the softer the shadow edges appear. This can be any value between 0 and the _sun_light value"}
      _sun_light:       = {Txt = "&" Hint = "Controls the brightness of the sun. It is the light produced from the sky* (see note). The value can range any where from 0 & up"}
    }
  }
}