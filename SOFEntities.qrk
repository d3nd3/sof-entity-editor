        Dekker.qtxfolder =
        {
          func_Dekker_console:e  = {origin = "0 0 0";desc = "Where Dekkers will go to turn on autoguns and make cool stuff happen.."}
          func_Dekker_diehere:e  = {origin = "0 0 0";desc = "Where Good Dekkers go when they die.."}
