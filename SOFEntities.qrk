        trigger_monsterjump:b = {t_triggerpoly=! speed = "200" height = "200" angle = "360";desc = "Walking monsters that touch this will jump in the direction of the trigger's angle"}
        trigger_movedown:b    = {t_triggerpoly=!                ;desc = "A trigger that forces thing downward. Meant to be used in conjunction with pushkill brush"}
        trigger_multiple:b    = {t_triggerpoly=! wait = "0.2"   ;desc = "Variable sized repeatable trigger. Must be targeted at one or more entities"}
        trigger_objectives:b  = {t_triggerpoly=!                ;desc = "Using this entity will toggle the trigger enabled/disabled. When enabled, the trigger will display a check your objectives screen message"}
        trigger_once:b        = {t_triggerpoly=!                ;desc = "Triggers once, then removes itself"}
        trigger_push:b        = {t_triggerpoly=! speed  = "1000";desc = "Pushes the player"}
        trigger_conquer:b     = {t_triggerpoly=!                ;desc = "Used to define the conquer area in Conquer The Bunker game mode"}
        trigger_relay:e       = {origin ="0 0 0"                ;desc = "This fixed size trigger cannot be touched, it can only be fired by other events"}
        trigger_safezone:b    = {t_triggerpoly=!                ;desc = "Using this entity will toggle whether it hides players or not"}
        trigger_sound:e       = {origin = "0 0 0" health = "128";desc = "Will trigger target when noisy things occur nearby"}
        trigger_useable:b     = {t_triggerpoly=!                ;desc = "A trigger that fires its targets only when the player hits the use key"}
      }
    }
