        trigger_hurt:b        = {t_triggerpoly=! dmg = "5"      ;desc = "Any entity that touches this will be hurt"}
        trigger_keep_using:b  = {t_triggerpoly=!                ;desc = "A trigger that keeps firing as long as the player hits the use key and keeps touching it"}
