    func_areaportal:form =
    {
      help ="This is a non-visible object that divides the world into"$0D"areas that are seperated when this portal is not activated."$0D"Usually enclosed in the middle of a door."
      targetname: = {Txt = "&" Hint = "The name to be targgeted from a trigger"}
    }
    func_breakable_brush:form =
    {
      help ="A breakable brush which has chunk size and type based upon the size and type of the brush."$0D"material values"$0D" 0 - MAT_NONE, (defaults to stone)"$0D" 1 - MAT_BRICK_BROWN,"$0D" 2 - MAT_BRICK_DBROWN,"$0D" 3 - MAT_BRICK_LBROWN,"$0D" 4 - MAT_BRICK_LGREY,"$0D" 5 - MAT_BRICK_DGREY,"$0D" 6 - MAT_BRICK_RED,"$0D" 7 - MAT_GLASS,"$0D" 8 - MAT_METAL_LGREY,"$0D" 9 - MAT_METAL_DGREY,"$0D"10 - MAT_METAL_RUSTY,"$0D"11 - MAT_METAL_SHINY,"$0D"12 - MAT_ROCK_BROWN,"$0D"13 - MAT_ROCK_LBROWN,"$0D"14 - MAT_ROCK_DBROWN,"$0D"15 - MAT_ROCK_LGREY,"$0D"16 - MAT_ROCK_DGREY,"$0D"17 - MAT_WOOD_LBROWN,"$0D"18 - MAT_WOOD_DBROWN,"$0D"19 - MAT_WOOD_LGREY,"$0D"20 - MAT_WOOD_DGREY,"$0D"21 - MAT_WALL_BLACK,"$0D"22 - MAT_WALL_BROWN,"$0D"23 - MAT_WALL_DARKBROWN,"$0D"24 - MAT_WALL_LIGHTBROWN,"$0D"25 - MAT_WALL_GREY,"$0D"26 - MAT_WALL_DARKGREY,"$0D"27 - MAT_WALL_LIGHTGREY,"$0D"28 - MAT_WALL_GREEN,"$0D"29 - MAT_WALL_ORANGE,"$0D"30 - MAT_WALL_RED,"$0D"31 - MAT_WALL_WHITE,"$0D"32 - MAT_ROCK_FLESH,"$0D"33 - MAT_WALL_STRAW,"$0D"34 - MAT_ROCK_SNOW,"$0D"surfacetype values"$0D"0 - defaults to stone... sorry Jersey { "$0D"14 - wood"$0D"17 - stone			"$0D"28 - metal"$0D"35 - blood (how does blood break? I don't know.)"$0D"37 - glass"$0D"40 - paper"
      spawnflags: = {Typ = "X1" Txt = "1" Cap = "INVINCIBLE"              Hint = "Intended to be used in conjunction with triggers"}
      spawnflags: = {Typ = "X2" Txt = "2" Cap = "PAINCHUNKS"              Hint = "Spawn debris when hurt (used for windows that shatter when first shot)"}
      //spawnflags:={Typ = "X4" Txt = "4" Cap = "DEKKER"                  Hint = "Only damageable by Dekker, will do damage to folks in the area when breaking"}
      spawnflags: = {Typ = "X8" Txt = "8" Cap = "CANT_DMG_IN_CAMERA_MODE" Hint = "You can damage this brush normally but it's invincible when player is viewing thru a camera"}
      count:      = {Txt = "&" Hint = "# of debris chunks to throw"}
      dmg:        = {Txt = "&" Hint = "How much damage will be done on its destruction (defaults 0)"}
      health:     = {Txt = "&" Hint = "Default is 100 -- Default for glass material is 50"}
      message:    = {Txt = "&" Hint = "Text to print when it dies"}
      volume:     = {Txt = "&" Hint = "Determine the radius of the damage. Damage falls off linearly to zero at this radius. Volume will default to whatever dmg is set to"}
      targetname: = {Txt = "&" Hint = "Make the brush killed from a trigger"}
      material: =
      {
        Txt = "&" Typ = "C" Hint = "Defines the type of debris to create when the brush breaks"
        Items = "None"$0D"Default"$0D"Brick Brown"$0D"Brick Dark Brown"$0D"Brick Light Brown"$0D"Brick Light Grey"$0D"Brick Dark Grey"$0D"Brick Red"$0D"Rock Brown"$0D"Rock Light Brown"$0D"Rock Dark Brown"$0D"Rock Light Grey"$0D"Rock Dark Grey"$0D"Rock Flesh"$0D"Rock Snow"$0D"Wood Light Brown"$0D"Wood Dark Brown"$0D"Wood Dark Grey"$0D"Wood Light Grey"$0D"Metal Light Grey"$0D"Metal Dark Grey"$0D"Metal Rusty"$0D"Metal Shiny"$0D"Wall Black"$0D"Wall Brown"$0D"Wall Dark Brown"$0D"Wall Light Brown"$0D"Wall Grey"$0D"Wall Dark Grey"$0D"Wall Light Grey"$0D"Wall Green"$0D"Wall Orange"$0D"Wall Red"$0D"Wall White"$0D"Wall Straw"$0D"Glass"
        Values = "-1"$0D"0"$0D"1"$0D"2"$0D"3"$0D"4"$0D"5"$0D"6"$0D"12"$0D"13"$0D"14"$0D"15"$0D"16"$0D"32"$0D"34"$0D"17"$0D"18"$0D"19"$0D"20"$0D"8"$0D"9"$0D"10"$0D"11"$0D"21"$0D"22"$0D"23"$0D"24"$0D"25"$0D"26"$0D"27"$0D"28"$0D"29"$0D"30"$0D"31"$0D"33"$0D"7"
      }
      mass: =
      {
        Txt = "&" Typ = "C" Hint = "Size of chunks to throw"
        Items = "Small"$0D"Medium"$0D"Big"
        Values = "1"$0D"2"$0D"3"
      }
      surfaceType: =
      {
        Txt = "&" Typ = "C" Hint = "Defines what sound to use when the brush breaks or takes damage"
        Items = "None"$0D"Default"$0D"Sand Yellow"$0D"Sand White"$0D"Sand Light Brown"$0D"Sand Dark Brown"$0D"Gravel Grey"$0D"Gravel Dark Brown"$0D"Gravel Light Brown"$0D"Liquid Blue"$0D"Liquid Green"$0D"Liquid Orange"$0D"Liquid Brown"$0D"Liquid Red"$0D"Liquid Black"$0D"Wood Light Brown"$0D"Wood Dark Brown"$0D"Wood Light Grey"$0D"Stone Light Grey"$0D"Stone Dark Grey"$0D"Stone Light Brown"$0D"Stone Dark Brown"$0D"Stone White"$0D"Stone Green"$0D"Stone Red"$0D"Stone Black"$0D"Glass"$0D"Glass Computer"$0D"Glass Green"$0D"Glass Brown"$0D"Metal 1"$0D"Metal 2"$0D"Metal Steam"$0D"Metal Water Jet"$0D"Metal Oil Spurt"$0D"Metal Chem Spurt"$0D"Metal Computers"$0D"Snow"$0D"Snow Light Brown"$0D"Snow Grey"$0D"Blood"$0D"Soda Machine"$0D"Paper Wall"$0D"Newspaper Damage"
        Values = "-1"$0D"0"$0D"2"$0D"3"$0D"4"$0D"5"$0D"6"$0D"7"$0D"8"$0D"10"$0D"11"$0D"12"$0D"13"$0D"27"$0D"36"$0D"14"$0D"15"$0D"16"$0D"17"$0D"18"$0D"19"$0D"20"$0D"21"$0D"22"$0D"23"$0D"24"$0D"37"$0D"38"$0D"25"$0D"26"$0D"28"$0D"1"$0D"42"$0D"29"$0D"30"$0D"31"$0D"32"$0D"9"$0D"33"$0D"34"$0D"35"$0D"39"$0D"40"$0D"41"
      }
    }
    func_button:form =
    {
      help ="When a button is touched, it moves some distance in the direction of it's angle, triggers all of it's targets, waits some time, then returns to it's original position where it can be triggered again."$0D"Buttons cannot be used by player if they have a targetname."
      spawnflags: = {Typ = "X1" Txt = "1" Cap = "AUTOUSE" Hint = "Button will be used on touch"}
      spawnflags: = {Typ = "X2" Txt = "2" Cap = "NOTQUAD" Hint = "Use frames 0-1 when up, 2-3 when down"}
      angle:      = {Txt = "&" Hint = "Determines the opening direction"}
      health:     = {Txt = "&" Hint = "If set, the button must be killed instead of touched"}
      lip:        = {Txt = "&" Hint = "Pixel lip remaining at end of move (default 4)"}
      message:    = {Txt = "&" Hint = "Text to print when the button is used"}
      sp_message: = {Txt = "&" Hint = "Is for a string package ID (numerical)"}
      speed:      = {Txt = "&" Hint = "Override the default 40 speed"}
      accel:      = {Txt = "&" Hint = "Rate of acceleration"}
      decel       = {Txt = "&" Hint = "Rate of deceleration"}
      wait:       = {Txt = "&" Hint = "Override the default 1 second wait (-1 = never return)"}
      pathtarget: = {Txt = "&" Hint = "Gets used when an entity that has this path_corner targeted touches it"}
      target:     = {Txt = "&" Hint = "All entities with a matching targetname will be used"}
      targetname: = {Txt = "&" Hint = "Entities with a matching target will be used"}
      soundname: =
      {
        Txt = "&" Typ = "C" Hint = "Sounds to be used for this button"
        Items = "[Button]Bleep 1"$0D"[Button]Bleep 2"$0D"[Button]Buzz"$0D"[Button]Elevator 1"$0D"[Button]HeliPad"$0D"[Door]Normal Wood Single"$0D"[Door]Normal Wood Double"$0D"[Door]Normal Wood Slide 1"$0D"[Door]Normal Swing Metal Light"$0D"[Door]Normal Swing Metal Norm 1"$0D"[Door]Normal Swing Metal Heavy"$0D"[Door]Normal Swing Metal Rusty"$0D"[Door]Normal Elevator"$0D"[Door]Normal Metal Garage"$0D"[Door]Normal Stall Metal"$0D"[Door]HiTech Blast Small"$0D"[Door]HiTech Blast Metal Light 1"$0D"[Door]HiTech Blast Metal Heavy 1"$0D"[Door]HiTech Swing Metal Heavy 1"$0D"[Door]Fridge"$0D"[Door]Pounder"$0D"[Door]Metal Gate"$0D"[Door]Gen Swing 1"$0D"[Door]Special Table"$0D"[Plat]Spikey"$0D"[Plat]Barrier"$0D"[Plat]Chain Elevator"
        Values = "ButtonBleep1"$0D"ButtonBleep2"$0D"ButtonBuzz"$0D"ButtonElevator1"$0D"HeliPadButton"$0D"DoorNormalWoodSingle"$0D"DoorNormalWoodDouble"$0D"DoorNormalWoodSlide1"$0D"DoorNormalSwingMetalLight"$0D"DoorNormalSwingMetalNorm1"$0D"DoorNormalSwingMetalHeavy"$0D"DoorNormalSwingMetalRusty"$0D"DoorNormalElevator"$0D"DoorNormalMetalGarage"$0D"DoorNormalStallMetal"$0D"DoorHiTechBlastSmall"$0D"DoorHiTechBlastMetalLight1"$0D"DoorHiTechBlastMetalHeavy1"$0D"DoorHiTechSwingMetalHeavy1"$0D"DoorFridge"$0D"DoorPounder"$0D"DoorMetalGate"$0D"DoorGenSwing1"$0D"DoorSpecialTable"$0D"PlatSpikey"$0D"PlatBarrier"$0D"PlatChainElevator"
      }
    }
    func_camerashake:form =
    {
      help ="Shakes the camera, centered on where the func is"
      bbox ='-8 -8 -8 8 8 8'
      count:      = {Txt = "&" Hint = "Intensity from 0 to 100 (default 30)"}
      health:     = {Txt = "&" Hint = "Radius of shaking. Will fall off over distance (default 300)"}
      delay:      = {Txt = "&" Hint = "The duration of the shaking in seconds (default 3)"}
      targetname: = {Txt = "&" Hint = "The name to be targgeted from a trigger"}
      style: =
      {
        Txt = "&" Typ = "C" Hint = "Makes a sound as it shakes the camera"
        Items = "Default"$0D"Dull explosion"
        values = "0"$0D"1"
      }
    }
    func_clock:form =
    {
      help ="Target a target_string with this"$0D"The default is to be a time of day clock"
      bbox ='-8 -8 -8 8 8 8'
      spawnflags: = {Typ = "X1" Txt = "1" Cap = "TIMER_UP"   Hint = "And TIMER_DOWN run for count seconds and the fire pathtarget"}
      spawnflags: = {Typ = "X2" Txt = "2" Cap = "TIMER_DOWN" Hint = "Run for count seconds and the fire pathtarget"}
      spawnflags: = {Typ = "X4" Txt = "4" Cap = "START_OFF"  Hint = "This entity must be used before it starts"}
      spawnflags: = {Typ = "X8" Txt = "8" Cap = "MULTI_USE"  Hint = "This entity can be used multiple times"}
      count:      = {Txt = "&" Hint = ""}
      target:     = {Txt = "&" Hint = "All entities with a matching targetname will be used"}
      targetname: = {Txt = "&" Hint = "The name to be targgeted from a trigger"}
      style: =
      {
        Txt = "&" Typ = "C" Hint = ""
        Items = "XX"$0D"XXXX"$0D"XXXXXX"
        values = "0"$0D"1"$0D"2"
      }
    }
    func_conveyor:form =
    {
      help ="Conveyors are stationary brushes that move what's on them."$0D"The brush should be have a surface with at least one current content enabled."
      spawnflags: = {Typ = "X1" Txt = "1" Cap = "START_ON" Hint = "Make this entity to begin activated"}
      spawnflags: = {Typ = "X2" Txt = "2" Cap = "TOGGLE"   Hint = "Using through trigger will activate/deactivate"}
      speed:      = {Txt = "&" Hint = "Speed (default 100)"}
      targetname: = {Txt = "&" Hint = "The name to be targgeted from a trigger"}
    }
    func_door:form =
    {
      help =""
      spawnflags: = {Typ = "X1"    Txt = "1"    Cap = "START_OPEN"    Hint = "The door to moves to its destination when spawned, and operate in reverse. It is used to temporarily or permanently close off an area when triggered (not useful for touch or takedamage doors)"}
      spawnflags: = {Typ = "X4"    Txt = "4"    Cap = "CRUSHER"       Hint = "If there's a monster blocking the door, gib it"}
      spawnflags: = {Typ = "X8"    Txt = "8"    Cap = "NOMONSTER"     Hint = "Monsters will not trigger this door"}
      spawnflags: = {Typ = "X16"   Txt = "16"   Cap = "LOCKED"        Hint = "Door won't open until used by a non-player entity"}
      spawnflags: = {Typ = "X32"   Txt = "32"   Cap = "TOGGLE"        Hint = "Wait in both the start and end states for a trigger event"}
      spawnflags: = {Typ = "X128"  Txt = "128"  Cap = "AUTOOPEN"      Hint = "Auto open the door when you are close to it"}
      spawnflags: = {Typ = "X256"  Txt = "256"  Cap = "USE_TARGET"    Hint = "Door can be used by player even if it has a targetname"}
      spawnflags: = {Typ = "X1024" Txt = "1024" Cap = "DUAL_TARGET"   Hint = "Door fires target on both open AND closed, instead of just open"}
      angle:      = {Txt = "&" Hint = "Determines the opening direction"}
      dmg:        = {Txt = "&" Hint = "Damage to inflict when blocked (default 2)"}
      health:     = {Txt = "&" Hint = "If set, door must be shot open"}
      lip:        = {Txt = "&" Hint = "Pixel lip remaining at end of move (default 8)"}
      message:    = {Txt = "&" Hint = "Is printed when the door is touched if it is a trigger door and it hasn't been fired yet"}
      sp_message: = {Txt = "&" Hint = "Is for a string package ID (numerical)"}
      speed:      = {Txt = "&" Hint = "Movement speed (default 100)"}
      wait:       = {Txt = "&" Hint = "Wait before returning (default 3, never return = -1)"}
      accel:      = {Txt = "&" Hint = "Rate of acceleration"}
      decel       = {Txt = "&" Hint = "Rate of deceleration"}
      team:       = {Txt = "&" Hint = "The name to be in pair with another door and make the two being used simultaneously"}
      target:     = {Txt = "&" Hint = "All entities with a matching targetname will be used"}
      targetname: = {Txt = "&" Hint = "If set, no touch field will be spawned and a remote button or trigger field activates the door"}
      soundName: =
      {
        Txt = "&" Typ = "C" Hint = "Name of the sound type for the door"
        Items = "[Door]Normal Wood Single"$0D"[Door]Normal Wood Double"$0D"[Door]Normal Wood Slide 1"$0D"[Door]Normal Swing Metal Light"$0D"[Door]Normal Swing Metal Norm 1"$0D"[Door]Normal Swing Metal Heavy"$0D"[Door]Normal Swing Metal Rusty"$0D"[Door]Normal Elevator"$0D"[Door]Normal Metal Garage"$0D"[Door]Normal Stall Metal"$0D"[Door]HiTech Blast Small"$0D"[Door]HiTech Blast Metal Light 1"$0D"[Door]HiTech Blast Metal Heavy 1"$0D"[Door]HiTech Swing Metal Heavy 1"$0D"[Door]Fridge"$0D"[Door]Pounder"$0D"[Door]Metal Gate"$0D"[Door]Gen Swing 1"$0D"[Door]Special Table"$0D"[Button]Bleep 1"$0D"[Button]Bleep 2"$0D"[Button]Buzz"$0D"[Button]Elevator 1"$0D"[Button]HeliPad"$0D"[Plat]Spikey"$0D"[Plat]Barrier"$0D"[Plat]Chain Elevator"
        Values = "DoorNormalWoodSingle"$0D"DoorNormalWoodDouble"$0D"DoorNormalWoodSlide1"$0D"DoorNormalSwingMetalLight"$0D"DoorNormalSwingMetalNorm1"$0D"DoorNormalSwingMetalHeavy"$0D"DoorNormalSwingMetalRusty"$0D"DoorNormalElevator"$0D"DoorNormalMetalGarage"$0D"DoorNormalStallMetal"$0D"DoorHiTechBlastSmall"$0D"DoorHiTechBlastMetalLight1"$0D"DoorHiTechBlastMetalHeavy1"$0D"DoorHiTechSwingMetalHeavy1"$0D"DoorFridge"$0D"DoorPounder"$0D"DoorMetalGate"$0D"DoorGenSwing1"$0D"DoorSpecialTable"$0D"ButtonBleep1"$0D"ButtonBleep2"$0D"ButtonBuzz"$0D"ButtonElevator1"$0D"HeliPadButton"$0D"PlatSpikey"$0D"PlatBarrier"$0D"PlatChainElevator"
      }
    }
    func_door_portcullis:form =
    {
      help ="Can only be opened by a trigger_keep_using."
      spawnflags: = {Typ = "X4" Txt = "4" Cap = "CRUSHER" Hint = "If there's a monster blocking the door, gib it"}
      angle:      = {Txt = "&" Hint = "Determines the opening direction"}
      dmg:        = {Txt = "&" Hint = "Damage to inflict when blocked (default 2)"}
      lip:        = {Txt = "&" Hint = "Pixel lip remaining at end of move (default 8)"}
      message:    = {Txt = "&" Hint = "Is printed when the door is touched if it is a trigger door and it hasn't been fired yet"}
      sp_message: = {Txt = "&" Hint = "Is for a string package ID (numerical)"}
      speed:      = {Txt = "up_speed"   Hint = "UPWARD movement speed (default 20)"}
      volume:     = {Txt = "down_speed" Hint = "DOWNWARD movement speed (default 10)"}
      wait:       = {Txt = "&" Hint = "Wait before returning (default 3, never return = -1)"}
      accel:      = {Txt = "&" Hint = "Rate of acceleration"}
      decel       = {Txt = "&" Hint = "Rate of deceleration"}
      team:       = {Txt = "&" Hint = "The name to be in pair with another door and make the two being used simultaneously"}
      target:     = {Txt = "&" Hint = "All entities with a matching targetname will be used"}
      targetname: = {Txt = "&" Hint = "Needs a name so the trigger_keep_using can open it"}
      soundName: =
      {
        Txt = "&" Typ = "C" Hint = "Name of the sound type for the door"
        Items = "[Door]Normal Wood Single"$0D"[Door]Normal Wood Double"$0D"[Door]Normal Wood Slide 1"$0D"[Door]Normal Swing Metal Light"$0D"[Door]Normal Swing Metal Norm 1"$0D"[Door]Normal Swing Metal Heavy"$0D"[Door]Normal Swing Metal Rusty"$0D"[Door]Normal Elevator"$0D"[Door]Normal Metal Garage"$0D"[Door]Normal Stall Metal"$0D"[Door]HiTech Blast Small"$0D"[Door]HiTech Blast Metal Light 1"$0D"[Door]HiTech Blast Metal Heavy 1"$0D"[Door]HiTech Swing Metal Heavy 1"$0D"[Door]Fridge"$0D"[Door]Pounder"$0D"[Door]Metal Gate"$0D"[Door]Gen Swing 1"$0D"[Door]Special Table"$0D"[Button]Bleep 1"$0D"[Button]Bleep 2"$0D"[Button]Buzz"$0D"[Button]Elevator 1"$0D"[Button]HeliPad"$0D"[Plat]Spikey"$0D"[Plat]Barrier"$0D"[Plat]Chain Elevator"
        Values = "DoorNormalWoodSingle"$0D"DoorNormalWoodDouble"$0D"DoorNormalWoodSlide1"$0D"DoorNormalSwingMetalLight"$0D"DoorNormalSwingMetalNorm1"$0D"DoorNormalSwingMetalHeavy"$0D"DoorNormalSwingMetalRusty"$0D"DoorNormalElevator"$0D"DoorNormalMetalGarage"$0D"DoorNormalStallMetal"$0D"DoorHiTechBlastSmall"$0D"DoorHiTechBlastMetalLight1"$0D"DoorHiTechBlastMetalHeavy1"$0D"DoorHiTechSwingMetalHeavy1"$0D"DoorFridge"$0D"DoorPounder"$0D"DoorMetalGate"$0D"DoorGenSwing1"$0D"DoorSpecialTable"$0D"ButtonBleep1"$0D"ButtonBleep2"$0D"ButtonBuzz"$0D"ButtonElevator1"$0D"HeliPadButton"$0D"PlatSpikey"$0D"PlatBarrier"$0D"PlatChainElevator"
      }
    }
    func_door_rotating:form =
    {
      help ="You need to have an origin brush as part of this entity. The center of that brush will be"$0D"the point around which it is rotated. It will rotate around the Z axis by default. You can"$0D"check either the X_AXIS or Y_AXIS box to change that."
      spawnflags: = {Typ = "X1"   Txt = "1"   Cap = "START_OPEN"  Hint = "The door to moves to its destination when spawned, and operate in reverse. It is used to temporarily or permanently close off an area when triggered (not useful for touch or takedamage doors)"}
      spawnflags: = {Typ = "X2"   Txt = "2"   Cap = "REVERSE"     Hint = "Will cause the door to rotate in the opposite direction"}
      spawnflags: = {Typ = "X4"   Txt = "4"   Cap = "CRUSHER"     Hint = "If there's a monster blocking the door, gib it"}
      spawnflags: = {Typ = "X8"   Txt = "8"   Cap = "NOMONSTER"   Hint = "Monsters will not trigger this door"}
      spawnflags: = {Typ = "X16"  Txt = "16"  Cap = "LOCKED"      Hint = "Door won't open until used by a non-player entity"}
      spawnflags: = {Typ = "X32"  Txt = "32"  Cap = "TOGGLE"      Hint = "Causes the door to wait in both the start and end states for a trigger event"}
      spawnflags: = {Typ = "X64"  Txt = "64"  Cap = "X_AXIS"      Hint = "Rotate to the 'X' axis"}
      spawnflags: = {Typ = "X128" Txt = "128" Cap = "Y_AXIS"      Hint = "Rotate to the 'Y' axis"}
      spawnflags: = {Typ = "X256" Txt = "256" Cap = "USE_TARGET"  Hint = "Door can be used by player even if it has a targetname"}
      spawnflags: = {Typ = "X512" Txt = "512" Cap = "IGNORE_HACK" Hint = "Use this flag if the door's origin is not at the edge"}
      angle:      = {Txt = "&" Hint = "Determines the opening direction"}
      distance:   = {Txt = "&" Hint = "Is how many degrees the door will be rotated"}
      dmg:        = {Txt = "&" Hint = "Damage to inflict when blocked (default 2)"}
      health:     = {Txt = "&" Hint = "If set, door must be shot open"}
      message:    = {Txt = "&" Hint = "Is printed when the door is touched if it is a trigger door and it hasn't been fired yet"}
      sp_message: = {Txt = "&" Hint = "Is for a string package ID (numerical)"}
      speed:      = {Txt = "&" Hint = "Rotating speed (default 100)"}
      wait:       = {Txt = "&" Hint = "Wait before returning (default 3, never return = -1)"}
      accel:      = {Txt = "&" Hint = "Rate of acceleration"}
      decel       = {Txt = "&" Hint = "Rate of deceleration"}
      team:       = {Txt = "&" Hint = "The name to be in pair with another door and make the two being used simultaneously"}
      targetname: = {Txt = "&" Hint = "If set, no touch field will be spawned and a remote button or trigger field activates the door"}
      soundName: =
      {
        Txt = "&" Typ = "C" Hint = "Name of the sound type for the door"
        Items = "[Door]Normal Wood Single"$0D"[Door]Normal Wood Double"$0D"[Door]Normal Wood Slide 1"$0D"[Door]Normal Swing Metal Light"$0D"[Door]Normal Swing Metal Norm 1"$0D"[Door]Normal Swing Metal Heavy"$0D"[Door]Normal Swing Metal Rusty"$0D"[Door]Normal Elevator"$0D"[Door]Normal Metal Garage"$0D"[Door]Normal Stall Metal"$0D"[Door]HiTech Blast Small"$0D"[Door]HiTech Blast Metal Light 1"$0D"[Door]HiTech Blast Metal Heavy 1"$0D"[Door]HiTech Swing Metal Heavy 1"$0D"[Door]Fridge"$0D"[Door]Pounder"$0D"[Door]Metal Gate"$0D"[Door]Gen Swing 1"$0D"[Door]Special Table"$0D"[Button]Bleep 1"$0D"[Button]Bleep 2"$0D"[Button]Buzz"$0D"[Button]Elevator 1"$0D"[Button]HeliPad"$0D"[Plat]Spikey"$0D"[Plat]Barrier"$0D"[Plat]Chain Elevator"
        Values = "DoorNormalWoodSingle"$0D"DoorNormalWoodDouble"$0D"DoorNormalWoodSlide1"$0D"DoorNormalSwingMetalLight"$0D"DoorNormalSwingMetalNorm1"$0D"DoorNormalSwingMetalHeavy"$0D"DoorNormalSwingMetalRusty"$0D"DoorNormalElevator"$0D"DoorNormalMetalGarage"$0D"DoorNormalStallMetal"$0D"DoorHiTechBlastSmall"$0D"DoorHiTechBlastMetalLight1"$0D"DoorHiTechBlastMetalHeavy1"$0D"DoorHiTechSwingMetalHeavy1"$0D"DoorFridge"$0D"DoorPounder"$0D"DoorMetalGate"$0D"DoorGenSwing1"$0D"DoorSpecialTable"$0D"ButtonBleep1"$0D"ButtonBleep2"$0D"ButtonBuzz"$0D"ButtonElevator1"$0D"HeliPadButton"$0D"PlatSpikey"$0D"PlatBarrier"$0D"PlatChainElevator"
      }
    }
