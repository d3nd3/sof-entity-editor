    func_snipercam_zoom:form =
    {
      help =""
      bbox ='-4 -4 -4 4 4 4'
      count:      = {Txt = "fov" Hint = "Desired fov, clamped to [6,60]. -1 resets to normal fov. Use to update"}
      targetname: = {Txt = "&"   Hint = "The name to be targgeted from a trigger"}
    }
    func_timer:form =
    {
      help ="The basic time between firing is a random time between"$0D"(wait - random) and (wait + random)"$0D"These can used but not touched."
      bbox ='-8 -8 -8 8 8 8'
      spawnflags: = {Typ = "X1" Txt = "1" Cap = "START_ON" Hint = "Make this entity to begin activated"}
      wait:       = {Txt = "&" Hint = "Base time between triggering all targets (default 1)"}
      random:     = {Txt = "&" Hint = "Wait variance (default 0)"}
      delay:      = {Txt = "&" Hint = "Delay before first firing when turned on (default 0)"}
      pausetime:  = {Txt = "&" Hint = "Additional delay used only the very first time and only if spawned with START_ON"}
      targetname: = {Txt = "&" Hint = "The name to be targgeted from a trigger"}
    }
    func_train:form =
    {
      help ="Trains are moving platforms that players can ride."$0D"The targets origin specifies the min point of the train at each corner."$0D"The train spawns at the first target it is pointing at."$0D"If the train is the target of a button or trigger, it will not begin moving until activated."
      spawnflags: = {Typ = "X1" Txt = "1" Cap = "START_ON"    Hint = "Make this entity to begin activated"}
      spawnflags: = {Typ = "X2" Txt = "2" Cap = "TOGGLE"      Hint = "Causes the door to wait in both the start and end states for a trigger event"}
      spawnflags: = {Typ = "X4" Txt = "4" Cap = "BLOCK_STOPS" Hint = "No damage to inflict when blocked"}
      dmg:        = {Txt = "&" Hint = "Damage to inflict when blocked (default 100)"}
      speed:      = {Txt = "&" Hint = "Determines how fast it moves (default 100)"}
      target:     = {Txt = "&" Hint = "All entities with a matching targetname will be used"}
      targetname: = {Txt = "&" Hint = "The name to be targgeted from a trigger"}
