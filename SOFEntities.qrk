    }
    func_remote_camera:form =
    {
      help =""
      bbox ='-4 -4 -4 4 4 4'
      spawnflags: = {Typ = "X1"  Txt = "1"  Cap = "ACTIVATOR_ONLY" Hint = "Only the activating client will see the remote camera view"}
      spawnflags: = {Typ = "X2"  Txt = "2"  Cap = "SCRIPTED"       Hint = "Puts player in godmode while camera is running and makes player non-solid"}
      spawnflags: = {Typ = "X4"  Txt = "4"  Cap = "NO_DELETE"      Hint = "Don't delete camera"}
      spawnflags: = {Typ = "X8"  Txt = "8"  Cap = "LW_ANIMATE"     Hint = "Camera will animate without a target after its initial spawn, but it still needs a target for its initial position. This should ONLY be used for one-shot cameras"}
      spawnflags: = {Typ = "X16" Txt = "16" Cap = "CAMERA_MODEL"   Hint = "Looking through camera model"}
      pathtarget: = {Txt = "&"   Hint = "Holds the name of the camera's owner entity (if any)"}
      style:      = {Txt = "fov" Hint = "Changes the player's FOV to assigned value while in camera if defined"}
      target:     = {Txt = "&"   Hint = "Holds the name of the entity to be looked at"}
      targetname: = {Txt = "&"   Hint = "The name to be targgeted from a trigger"}
      volume: =
      {
        Txt = "mode" Typ = "C" Hint = "Defines the cinematic mode 0 = normal (standard FPS, player can shoot), 1 = third person, 2 = letterbox, 4 = monitor (graphic overlay border), 8 = remote with no special features, 16 = sniper scope"
        Items = "Normal"$0D"Third person"$0D"Letterbox"$0D"Monitor"$0D"Remote"$0D"Sniper scope"
        values = "0"$0D"1"$0D"2"$0D"4"$0D"8"$0D"16"
      }
    }
    func_rotating:form =
    {
      help ="You need to have an origin brush as part of this entity. The center of that brush will be the point around which it is rotated. It will rotate around the Z axis by default. You can check either the X_AXIS or Y_AXIS box to change that"
      spawnflags: = {Typ = "X1"   Txt = "1"   Cap = "START_ON"      Hint = "Make this entity to begin activated"}
      spawnflags: = {Typ = "X2"   Txt = "2"   Cap = "REVERSE"       Hint = "Will cause the it to rotate in the opposite direction"}
      spawnflags: = {Typ = "X4"   Txt = "64"  Cap = "X_AXIS"        Hint = "Rotate to the 'X' axis"}
      spawnflags: = {Typ = "X8"   Txt = "128" Cap = "Y_AXIS"        Hint = "Rotate to the 'Y' axis"}
      spawnflags: = {Typ = "X16"  Txt = "16"  Cap = "TOUCH_PAIN"    Hint = "Inflict damage when touched"}
      spawnflags: = {Typ = "X32"  Txt = "32"  Cap = "STOP"          Hint = "Mean it will stop moving instead of pushing entities"}
      spawnflags: = {Typ = "X64"  Txt = "64"  Cap = "ANIMATED"      Hint = "Have the texture to be animated if it was designed for"}
      spawnflags: = {Typ = "X128" Txt = "128" Cap = "ANIMATED_FAST" Hint = "Have the texture to be animated fast if it was designed for"}
      dmg:        = {Txt = "&" Hint = "Damage to inflict when touched (default 2)"}
